ORDERFLOW_APP_NAME=OrderFlow Integrator
ORDERFLOW_APP_VERSION=0.2.0
ORDERFLOW_ENVIRONMENT=development
ORDERFLOW_LOG_LEVEL=INFO
ORDERFLOW_DEFAULT_CURRENCY=USD
ORDERFLOW_CORS_ORIGINS=*
ORDERFLOW_DATABASE_URL=sqlite:///./orderflow.db
ORDERFLOW_REDIS_URL=redis://localhost:6379/0
ORDERFLOW_API_KEY=change-this-in-production
ORDERFLOW_CELERY_EAGER=false
ORDERFLOW_MAX_DELIVERY_ATTEMPTS=3
CLOUDFLARE_TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here
